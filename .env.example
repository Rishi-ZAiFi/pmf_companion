# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string. Must point to a database with the pgvector
# extension enabled. Example: postgresql://user:password@host:5432/dbname
DATABASE_URL=

# ── Redis / BullMQ ────────────────────────────────────────────────────────────
# Redis connection string used by BullMQ for job queues and as the app cache.
# Example: redis://localhost:6379  or  rediss://user:password@host:6380
REDIS_URL=

# ── OpenAI ────────────────────────────────────────────────────────────────────
# Used for text-embedding-3-small (1536-dim) and Chat Completions.
OPENAI_API_KEY=

# ── NextAuth ──────────────────────────────────────────────────────────────────
# A random string of at least 32 characters used to sign and encrypt JWTs.
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
# The canonical URL of the application (no trailing slash).
NEXTAUTH_URL=http://localhost:3000

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── SendGrid ──────────────────────────────────────────────────────────────────
# Used for transactional email (campaign delivery, notifications, digests).
SENDGRID_API_KEY=

# ── Twilio ────────────────────────────────────────────────────────────────────
# Used for outbound SMS campaign delivery and inbound reply routing.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# E.164 format, e.g. +15551234567
TWILIO_PHONE_NUMBER=

# ── Vapi ──────────────────────────────────────────────────────────────────────
# Used for outbound voice call campaigns and transcript webhooks.
VAPI_API_KEY=
# The phone number ID provisioned in the Vapi dashboard (used as the caller ID).
VAPI_PHONE_NUMBER_ID=

# ── Stripe ────────────────────────────────────────────────────────────────────
# Use test keys (sk_test_...) for development and live keys (sk_live_...) for production.
STRIPE_SECRET_KEY=
# Obtain from the Stripe Dashboard → Webhooks → your endpoint → Signing secret.
STRIPE_WEBHOOK_SECRET=
# Stripe price IDs for each paid plan tier.
# Find these in the Stripe Dashboard → Products → (plan) → Pricing.
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_ENTERPRISE=

# ── Twitter/X API v2 ─────────────────────────────────────────────────────
# Bearer Token for read-only access to the Twitter v2 recent search endpoint.
# Create at https://developer.twitter.com/en/portal/dashboard
TWITTER_BEARER_TOKEN=

# ── Slack ─────────────────────────────────────────────────────────────────
# Create a Slack app at https://api.slack.com/apps and add the OAuth redirect
# URL: <NEXTAUTH_URL>/api/integrations/slack/callback
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# ── HubSpot ───────────────────────────────────────────────────────────────
# Create an app at https://developers.hubspot.com/docs/api/creating-an-app
# Add the OAuth redirect URL: <NEXTAUTH_URL>/api/integrations/hubspot/callback
# Required scopes: crm.objects.contacts.read, crm.objects.contacts.write
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=

# ── Intercom ──────────────────────────────────────────────────────────────
# Create an app at https://developers.intercom.com/building-apps/docs/setting-up-oauth
# Add the OAuth redirect URL: <NEXTAUTH_URL>/api/integrations/intercom/callback
INTERCOM_CLIENT_ID=
INTERCOM_CLIENT_SECRET=

# ── Encryption ────────────────────────────────────────────────────────────
# 32-byte hex-encoded key for AES-256-GCM encryption of integration tokens.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# ── AWS ───────────────────────────────────────────────────────────────────────
# IAM credentials with s3:PutObject / s3:GetObject permissions on the bucket below.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# S3 bucket for call recordings and exported reports.
AWS_S3_BUCKET=
# AWS region where the bucket lives, e.g. us-east-1
AWS_REGION=
